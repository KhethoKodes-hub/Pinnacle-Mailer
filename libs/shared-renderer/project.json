{
  "name": "shared-renderer",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared-renderer/src",
  "projectType": "library",
  "tags": ["type:lib", "scope:shared"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/shared-renderer",
        "main": "libs/shared-renderer/src/index.ts",
        "tsConfig": "libs/shared-renderer/tsconfig.lib.json",
        "assets": ["libs/shared-renderer/*.md"]
      }
    }
  }
}
