{
  "name": "pinnacle-mailer",
  "version": "1.0.0",
  "description": "Email template manager for Pinnacle Rewards",
  "main": "index.js",
  "scripts": {
    "dev:app": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "nx dev frontend --port=4200",
    "dev:backend": "nx serve backend",
    "build": "nx build frontend",
    "build:all": "nx nrun-many -t build --exclude pinnacle-mailer",
    "lint": "nx run-many -t lint",
    "db:generate": "prisma generate --schema apps/backend/prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema apps/backend/prisma/schema.prisma",
    "db:seed": "tsx apps/backend/prisma/seed.ts",
    "db:demo-reset": "npm run db:generate && prisma migrate reset --force --skip-generate --schema apps/backend/prisma/schema.prisma && npm run db:seed"
  },
  "keywords": [],
  "author": "Khetho Mngomezulu",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/eslint": "^23.0.1",
    "@nx/eslint-plugin": "23.0.1",
    "@nx/js": "^23.0.1",
    "@nx/nest": "^23.0.1",
    "@nx/next": "^23.0.1",
    "@nx/node": "^23.0.1",
    "@nx/web": "^23.0.1",
    "@nx/webpack": "23.0.1",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^9.8.0",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "jsonc-eslint-parser": "^2.1.0",
    "nx": "23.0.1",
    "prettier": "~3.6.2",
    "tslib": "^2.3.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "webpack": "^5.101.3",
    "webpack-cli": "^7.0.0",
    "webpack-dev-server": "^5.2.1"
  },
  "nx": {},
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "6.16.2",
    "@types/jsonwebtoken": "^9.0.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "jsonwebtoken": "^9.0.3",
    "mjml": "^5.3.0",
    "multer": "^2.2.0",
    "nestjs-pino": "^4.6.1",
    "next": "~16.1.6",
    "next-auth": "^4.24.14",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "6.16.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1"
  }
}
